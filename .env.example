# --- OpenAI ---
# API key with Realtime API access. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Twilio ---
# From https://console.twilio.com (Account SID + Auth Token)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# The Twilio number you bought, in E.164 format. This is the single number you call from.
TWILIO_FROM_NUMBER=+1...

# --- Target ---
# The PGAI assessment test line. Do NOT change this. Only ever call this number.
TARGET_NUMBER=+18054398008

# --- Public URL ---
# Your ngrok https URL WITHOUT the scheme, e.g. abc1234.ngrok-free.app
# Start ngrok with:  ngrok http 8000
PUBLIC_HOSTNAME=your-subdomain.ngrok-free.app

# --- Server ---
PORT=8000

# Voice for the patient bot (alloy, ash, ballad, coral, echo, sage, shimmer, verse)
REALTIME_VOICE=coral
# Realtime model
REALTIME_MODEL=gpt-realtime-mini
